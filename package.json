{
	"name": "logtrace",
	"description": "Lightweight event-tracking dashboard on Cloudflare Workers + D1.",
	"cloudflare": {
		"label": "Worker + D1 Database",
		"products": [
			"Workers",
			"D1"
		],
		"categories": [
			"storage"
		],
		"docs_url": "https://developers.cloudflare.com/d1/",
		"preview_icon_url": "https://imagedelivery.net/wSMYJvS3Xw-n339CbDyDIA/6c63cca8-354a-4951-45a0-d58769ac6f00/public",
		"preview_image_url": "https://imagedelivery.net/wSMYJvS3Xw-n339CbDyDIA/aa6158f1-7711-4485-f134-a8c802c0a800/preview",
		"publish": true
	},
	"devDependencies": {
		"typescript": "5.9.3",
		"wrangler": "4.56.0"
	},
	"private": true,
	"scripts": {
		"postinstall": "npm --prefix web install",
		"cf-typegen": "wrangler types",
		"check": "tsc && wrangler deploy --dry-run",
		"build:web": "npm --prefix web run build",
		"dev:web": "npm --prefix web run dev",
		"dev:worker": "wrangler dev --port 8282",
		"dev": "npm run seedLocalD1 && npm run build:web && wrangler dev --port 8282",
		"deploy": "wrangler deploy",
		"predeploy": "npm run build:web && wrangler d1 migrations apply DB --remote",
		"seedLocalD1": "wrangler d1 migrations apply DB --local"
	}
}
